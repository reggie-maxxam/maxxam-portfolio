    {
      "id": "send-results-email-001",
      "name": "Send Results Email",
      "type": "n8n-nodes-base.gmail",
      "position": [
        2250,
        300
      ],
      "parameters": {
        "sendTo": "={{ $json.emailTo }}",
        "subject": "={{ $json.firstName }}, your AI Readiness Score: {{ $json.totalScore }}% \u2014 {{ $json.category }}",
        "message": "",
        "options": {
          "attachmentsUi": {
            "attachmentsBinary": [
              {
                "property": "pdfFile"
              }
            ]
          },
          "appendAttributionToBody": false
        },
        "emailType": "html",
        "messageHtml": "=<div style=\"font-family:-apple-system,Helvetica,Arial,sans-serif; max-width:580px; margin:0 auto; padding:20px; color:#1a1a1a;\">\n\n  <!-- Header -->\n  <div style=\"text-align:center; padding:24px 28px; background:linear-gradient(135deg,#1a1a1a 0%,#2d2d2d 100%); border-radius:12px; margin-bottom:24px;\">\n    <div style=\"font-size:22px; font-weight:700; color:#FCC01E;\">MAXXAM AI</div>\n    <div style=\"color:#ccc; font-size:11px; margin-top:4px;\">AI Readiness Scorecard Results</div>\n  </div>\n\n  <p style=\"font-size:17px; font-weight:600; margin-bottom:8px;\">Hey {{ $json.firstName }}! \ud83d\udc4b</p>\n  <p style=\"font-size:15px; color:#444; line-height:1.75; margin-bottom:20px;\">Your AI Readiness Score is in. Here's how you scored across all 6 categories.</p>\n\n  <!-- Score Block -->\n  <div style=\"text-align:center; padding:28px; background:linear-gradient(135deg,#FCC01E 0%,#e6ac00 100%); border-radius:12px; margin-bottom:20px;\">\n    <div style=\"font-size:12px; font-weight:600; color:#1a1a1a; letter-spacing:0.08em; text-transform:uppercase;\">Overall Score</div>\n    <div style=\"font-size:56px; font-weight:800; color:#1a1a1a; line-height:1.1;\">{{ $json.totalScore }}<span style=\"font-size:22px;\">%</span></div>\n    <div style=\"display:inline-block; margin-top:12px; padding:8px 20px; background:#1a1a1a; color:#FCC01E; border-radius:50px; font-size:14px; font-weight:600;\">{{ $json.category }}</div>\n  </div>\n\n  <!-- Weakest Category Callout -->\n  <div style=\"padding:14px 18px; background:#fff8e1; border-left:4px solid #FCC01E; border-radius:6px; margin-bottom:20px; font-size:14px; color:#92400e;\">\n    \u26a0\ufe0f <strong>Your priority gap:</strong> {{ $json.weakestCategoryLabel }} \u2014 your PDF covers exactly what to build first.\n  </div>\n\n  <p style=\"font-size:14px; color:#444; line-height:1.75; margin-bottom:16px;\">Your personalized report is attached \u2014 it includes your full breakdown by category, your weakest area, and your exact next steps.</p>\n\n  {{ $json.categoryTag === 'hot-lead' || $json.categoryTag === 'warm-lead' ? '<div style=\"text-align:center; padding:24px; background:#1a1a1a; border-radius:12px; margin:20px 0;\"><div style=\"color:#fff; font-size:16px; font-weight:600; margin-bottom:12px;\">Ready to turn your score into a plan?</div><a href=\"' + $json.calLink + '\" style=\"display:inline-block; padding:13px 32px; background:#FCC01E; color:#1a1a1a; text-decoration:none; border-radius:50px; font-weight:700; font-size:15px;\">' + $json.primaryCTA + '</a><div style=\"margin-top:8px; font-size:11px; color:#888;\">Free 45-min discovery call \u00b7 No commitment</div></div>' : '<p style=\"font-size:14px; color:#444; line-height:1.75;\">When you\\'re ready to move, booking a free discovery call is the fastest way to turn this score into a roadmap: <a href=\"' + $json.calLink + '\" style=\"color:#FCC01E;\">tinyurl.com/maxxam-call</a></p>' }}\n\n  <p style=\"font-size:15px; color:#444; margin-top:20px;\">To your success,<br><strong>Reggie Johnson</strong><br>MAXXAM AI</p>\n\n  <div style=\"text-align:center; padding:16px; border-top:1px solid #e5e7eb; color:#999; font-size:11px; margin-top:24px;\">\n    <p>\u00a9 {{ $now.format('yyyy') }} MAXXAM AI \u00b7 Newnan, Georgia \u00b7 <a href=\"https://maxxam.ai\" style=\"color:#FCC01E;\">maxxam.ai</a></p>\n    <p>Questions? Just reply to this email \u2014 Reggie reads every one.</p>\n  </div>\n\n</div>"
