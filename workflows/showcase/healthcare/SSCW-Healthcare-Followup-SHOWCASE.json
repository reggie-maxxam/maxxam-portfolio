      ]
    },
    "SMS Cancel Confirmation": {
      "main": [
        [{ "node": "Check & Notify Waitlist", "type": "main", "index": 0 }]
      ]
    },
    "Check & Notify Waitlist": {
      "main": [
        [{ "node": "Log to Activity Sheet", "type": "main", "index": 0 }]
      ]
    },
    "No-Show Staff Alert": {
      "main": [
        [{ "node": "Re-Engagement SMS", "type": "main", "index": 0 }]
      ]
    },
    "Re-Engagement SMS": {
      "main": [
        [{ "node": "Log to Activity Sheet", "type": "main", "index": 0 }]
      ]
    },
    "Log to Activity Sheet": {
      "main": [
        [{ "node": "Respond to Cal.com", "type": "main", "index": 0 }]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
