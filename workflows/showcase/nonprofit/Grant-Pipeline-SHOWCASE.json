{
  "name": "Grant Pipeline Automation",
  "nodes": [
    {
      "parameters": {
        "content": "## Grant Pipeline Automation\n\nAutomates the full grant opportunity lifecycle — from new opportunity intake through funder alignment scoring, narrative brief generation, and deadline tracking. Only high-fit grants (score ≥ 7) enter the writing pipeline. Low-fit opportunities are filtered automatically, protecting the grant writer's time.",
        "height": 140,
        "width": 520,
        "color": 7
      },
      "id": "sticky-title",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [-200, -180]
    },
