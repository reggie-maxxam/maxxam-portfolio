      "parameters": {
        "content": "**Intake**\nCapture grant opportunity details via form submission or webhook",
        "height": 90,
        "width": 200,
        "color": 4
      },
      "id": "sticky-intake",
      "name": "Sticky Note1",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [0, -160]
    },
    {
      "parameters": {
        "content": "**Scoring**\n6 dimensions · max score 10\nMission · Geography · Org Type · Track Record · Budget · Relationship",
        "height": 100,
        "width": 210,
        "color": 4
      },
      "id": "sticky-scoring",
      "name": "Sticky Note2",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [360, -160]
    },
    {
      "parameters": {
        "content": "**Routing**\n≥ 7 → proceed · 5–6 → conditional review · < 5 → pass",
        "height": 90,
