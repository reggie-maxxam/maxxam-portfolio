    {
      "parameters": {
        "httpMethod": "POST",
        "path": "grant-intake",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "node-webhook",
      "name": "New Grant Opportunity",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 300],
      "webhookId": "grant-intake-webhook"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "set-funder",
