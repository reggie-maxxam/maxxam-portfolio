      "id": "node-set",
      "name": "Parse Grant Inputs",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [200, 300]
    },
    {
      "parameters": {
        "jsCode": "// ── MAXXAM AI — Redacted Implementation ─────────────────────────\n//\n// Purpose: Funder alignment scoring — 6 dimensions, max score 10\n//\n// Dimension 1 — Mission Alignment (0–3)\n//   3: Direct match (health + arts/culture + faith engagement)\n//   2: Strong overlap (community health OR social determinants)\n//   1: Adjacent (general community development or youth)\n//   0: Poor match\n//\n// Dimension 2 — Geographic Eligibility (0–2)\n//   2: Local/regional match (metro, county, or state)\n//   1: National funder, eligible but not priority\n//   0: Outside scope\n//\n// Dimension 3 — Organization Type Eligibility (0–1)\n//   1: 501(c)(3) required or preferred — org qualifies\n//   0: Restricted to org types that exclude this org\n//\n// Dimension 4 — Track Record Alignment (0–2)\n//   2: Directly relevant prior work\n//   1: Partially relevant — related but not exact\n//   0: No relevant track record\n//\n// Dimension 5 — Budget Fit (0–1)\n//   1: Grant amount matches program cost within 30%\n//   0: Too small to deliver or too large to absorb credibly\n//\n// Dimension 6 — Existing Relationship (0–1)\n//   1: Prior contact with program officer or received prior funding\n//   0: Cold application\n//\n// Outputs: alignmentScore (0–10), recommendation (proceed/conditional/pass),\n//          scoreBreakdown{}, daysUntilDeadline\n//\n// Full implementation available to MAXXAM AI clients.\n// → Book a discovery call: https://tinyurl.com/maxxam-call\n// ────────────────────────────────────────────────────────────────\n\nreturn { json: {} };"
      },
      "id": "node-scoring",
      "name": "Funder Alignment Scoring",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 300]
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{ $json.recommendation }}",
        "rules": {
          "rules": [
            {
              "value2": "pass",
              "output": 0
            },
            {
              "value2": "conditional",
              "output": 1
            },
            {
              "value2": "proceed",
              "output": 2
            }
          ]
        },
        "fallbackOutput": 0
      },
      "id": "node-switch",
      "name": "Route by Score",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [640, 300]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.grantWriterEmail }}",
        "subject": "Grant Pass: {{ $json.funder_name }} — Score {{ $json.alignmentScore }}/10",
        "emailType": "html",
        "message": "={{ $json.passNotificationHtml }}",
        "options": {}
      },
      "id": "node-gmail-pass",
      "name": "Notify — Not a Fit",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [880, 100]
    },
    {
      "parameters": {
        "sendTo": "={{ $json.grantWriterEmail }}",
        "subject": "Grant Review Needed: {{ $json.funder_name }} — Score {{ $json.alignmentScore }}/10",
        "emailType": "html",
        "message": "={{ $json.conditionalReviewHtml }}",
        "options": {}
      },
      "id": "node-gmail-conditional",
      "name": "Notify — Conditional Review",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [880, 300]
    },
    {
      "parameters": {
        "jsCode": "// ── MAXXAM AI — Redacted Implementation ─────────────────────────\n//\n// Purpose: Generate structured first-draft narrative brief from org boilerplate\n//\n// Inputs: alignmentScore, scoreBreakdown, funder_name, focus_area,\n//         program_name, target_population, expected_outcomes, budget_range\n//\n// Output sections (7):\n//   1. Executive Summary — ask, problem, solution, impact, org positioning\n//   2. Needs / Problem Statement — local data, gap framing, funder language match\n//   3. Project Description — goals, SMART objectives, activities, timeline, partners\n//   4. Evaluation Plan — indicators, data sources, output vs. outcome distinction\n//   5. Organizational Capacity — from org boilerplate (verified data only)\n//   6. Budget Narrative — personnel, contractors, supplies, travel, indirect\n//   7. Sustainability Plan — revenue mix, partner continuation, post-grant plan\n//\n// Also outputs: narrativeBriefDocUrl (Google Doc), subjectLine, daysUntilDeadline\n//\n// Full implementation available to MAXXAM AI clients.\n// → Book a discovery call: https://tinyurl.com/maxxam-call\n// ────────────────────────────────────────────────────────────────\n\nreturn { json: {} };"
      },
      "id": "node-narrative",
      "name": "Generate Narrative Brief",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [880, 500]
    },
