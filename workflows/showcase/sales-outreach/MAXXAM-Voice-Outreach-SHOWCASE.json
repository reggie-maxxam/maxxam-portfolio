        1340,
        640
      ],
      "parameters": {
        "messages": {
          "messageValues": [
            {
              "message": "You are classifying the outcome of a cold sales call transcript. Classify the outcome as exactly one of:\n\n- answered_interested: Prospect engaged, expressed curiosity, agreed to learn more, or said yes to a call\n- answered_declined: Prospect clearly said not interested, stop calling, or remove me\n- wrong_number: This was the wrong person or a personal number, not the business owner\n- no_answer: No meaningful conversation (immediate hang-up, less than 5 seconds)\n\nReturn ONLY valid JSON. No explanation.",
              "type": "SystemMessagePromptTemplate"
            },
            {
              "message": "=Transcript:\n{{ $json.transcript }}\n\nDisconnection reason: {{ $json.disconnection_reason }}\nCall duration: {{ Math.round($json.duration_ms / 1000) }} seconds\n\nReturn JSON: {\"outcome\": \"<one of the four values>\", \"notes\": \"<1 sentence summary>\"}",
              "type": "HumanMessagePromptTemplate"
            }
          ]
        },
        "options": {}
      }
