{
  "name": "AI Lead Management with GoHighLevel CRM & Google Drive",
  "nodes": [
    {
      "id": "gmail-trigger-001",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmail",
      "position": [
        100,
        320
      ],
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "simple": false,
        "filters": {
          "includeSpamTrash": false
        }
      },
      "credentials": {
        "gmailOAuth2": {
          "id": "{{ $credentials.gmailOAuth2 }}",
          "name": "Gmail Account"
        }
      },
      "typeVersion": 2.1
    },
    {
      "id": "switch-rules-001",
      "name": "Switch",
      "type": "n8n-nodes-base.switch",
      "position": [
        300,
        320
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "lead_email",
              "conditions": {
                "options": {
                  "leftValue": "",
                  "caseSensitive": true,
                  "typeValidation": "strict"
                },
                "combinator": "and",
                "conditions": [
                  {
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    },
                    "leftValue": "={{ $json.subject }}",
                    "rightValue": "lead"
                  }
                ]
              },
              "renameOutput": true
            },
            {
              "outputKey": "partnership",
              "conditions": {
                "options": {
                  "leftValue": "",
                  "caseSensitive": true,
                  "typeValidation": "strict"
                },
                "combinator": "or",
                "conditions": [
                  {
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    },
                    "leftValue": "={{ $json.subject }}",
                    "rightValue": "partnership"
                  },
                  {
                    "operator": {
                      "type": "string",
                      "operation": "contains"
                    },
                    "leftValue": "={{ $json.subject }}",
                    "rightValue": "collaboration"
                  }
                ]
              },
              "renameOutput": true
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "typeVersion": 3.1
    },
    {
      "id": "ghl-add-contact-001",
      "name": "Add lead to CRM",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        400,
        160
      ],
      "parameters": {
        "method": "POST",
        "url": "=https://rest.gohighlevel.com/v1/contacts/",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "goHighLevelApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.goHighLevelApi.accessToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "email",
              "value": "={{ $json.from }}"
            },
            {
              "name": "firstName",
              "value": "={{ $json.from.split('@')[0] }}"
            },
            {
              "name": "companyName",
              "value": "={{ $json.from.split('@')[1] }}"
            },
            {
              "name": "source",
              "value": "Gmail Automation"
            },
            {
              "name": "tags",
              "value": [
                "New Lead",
                "Email Inquiry"
              ]
            },
            {
              "name": "customFields",
              "value": {
                "email_subject": "={{ $json.subject }}",
                "inquiry_date": "={{ $now }}",
                "lead_status": "New"
              }
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "goHighLevelApi": {
          "id": "{{ $credentials.goHighLevelApi }}",
          "name": "GoHighLevel API"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "openai-model-crm-001",
      "name": "OpenAI Chat Model1",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "position": [
        220,
        320
      ],
      "parameters": {
        "model": "chatgpt-4o-latest",
        "options": {
          "temperature": 0.2,
          "maxTokens": 800
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "{{ $credentials.openAiApi }}",
          "name": "OpenAI API"
        }
      },
      "typeVersion": 1
    },
    {
      "id": "ghl-crm-agent-001",
      "name": "GoHighLevel CRM Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        500,
        200
      ],
      "parameters": {
        "text": "=Process this lead for GoHighLevel CRM:\n\nEmail: {{ $json.from }}\nSubject: {{ $json.subject }}\nCompany Domain: {{ $json.from.split('@')[1] }}\n\nExtract and format lead information for CRM entry including:\n1. Contact details\n2. Company information\n3. Lead source and classification\n4. Next action steps",
        "options": {
          "systemMessage": "You are a GoHighLevel CRM specialist. Process incoming leads and format them properly for CRM entry. Focus on data quality, lead scoring, and actionable next steps. Always provide structured output for CRM integration.",
          "maxIterations": 3
        }
      },
      "typeVersion": 1.7
    },
    {
      "id": "if-condition-001",
      "name": "If",
      "type": "n8n-nodes-base.if",
      "position": [
        700,
        200
      ],
      "parameters": {
        "conditions": {
          "options": {
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              },
              "leftValue": "={{ $json.from }}"
            }
          ]
        }
      },
      "typeVersion": 2
    },
    {
      "id": "find-website-url-001",
      "name": "Find website URL",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        900,
        160
      ],
      "parameters": {
        "url": "=https://api.hunter.io/v2/domain-search?domain={{ $json.from.split('@')[1] }}&api_key={{ $credentials.hunterApi }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false,
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpBasicAuth": {
          "id": "{{ $credentials.hunterApi }}",
          "name": "Hunter API"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "scrape-website-url-001",
      "name": "Scrape website URL",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1100,
        100
      ],
      "parameters": {
        "url": "={{ $('Find website URL').item.json.data.organization.website || 'https://example.com' }}",
        "options": {
          "response": {
            "response": {
              "fullResponse": false,
              "responseFormat": "text"
            }
          },
          "timeout": 10000
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "markdown-conversion-001",
      "name": "Markdown",
      "type": "n8n-nodes-base.htmlExtract",
      "position": [
        1300,
        100
      ],
      "parameters": {
        "operation": "extractContent",
        "extractionMode": "html",
        "sourceData": "={{ $json.data }}",
        "options": {}
      },
      "typeVersion": 1
    },
    {
      "id": "find-linkedin-url-001",
      "name": "Find LinkedIn URL",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        1100,
        200
      ],
      "parameters": {
        "url": "=https://api.proxycrawl.com/scraper?token={{ $credentials.proxycrawlApi }}&url=https://www.google.com/search?q={{ encodeURIComponent($json.from.split('@')[1]) }}+linkedin",
        "options": {
          "response": {
            "response": {
              "fullResponse": false,
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "httpBasicAuth": {
          "id": "{{ $credentials.proxycrawlApi }}",
          "name": "ProxyCrawl API"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "lead-summary-agent-001",
      "name": "Lead summary Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        1500,
        160
      ],
      "parameters": {
        "text": "=Create comprehensive lead analysis for GoHighLevel CRM:\n\nEmail: {{ $('Gmail Trigger').item.json.from }}\nSubject: {{ $('Gmail Trigger').item.json.subject }}\nWebsite Content: {{ $('Markdown').item.json.content || 'Not available' }}\nLinkedIn Info: {{ $('Find LinkedIn URL').item.json.linkedin_url || 'Not found' }}\n\nGenerate detailed lead profile with:\n1. Company overview and industry\n2. Business potential and revenue opportunity\n3. Pain points and solution fit\n4. Recommended sales approach\n5. Priority level and next actions\n6. CRM tags and categorization",
        "options": {
          "systemMessage": "You are an expert lead analyst for GoHighLevel CRM. Create comprehensive, actionable lead profiles that help sales teams prioritize prospects and craft targeted approaches. Focus on business value, competitive analysis, and strategic sales recommendations with specific CRM categorization.",
          "maxIterations": 4
        }
      },
      "typeVersion": 1.7
    },
    {
      "id": "openai-model-lead-001",
      "name": "OpenAI Chat Model2",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "position": [
        1320,
        320
      ],
      "parameters": {
        "model": "chatgpt-4o-latest",
        "options": {
          "temperature": 0.3,
          "maxTokens": 2000
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "{{ $credentials.openAiApi }}",
          "name": "OpenAI API"
        }
      },
      "typeVersion": 1
    },
    {
      "id": "create-gdrive-folder-001",
      "name": "Create Google Drive Folder",
      "type": "n8n-nodes-base.googleDrive",
      "position": [
        1700,
        100
      ],
      "parameters": {
        "operation": "create",
        "resource": "folder",
        "name": "=Lead Analysis - {{ $('Gmail Trigger').item.json.from.split('@')[1] }} - {{ $now.format('yyyy-MM-dd') }}",
        "options": {
          "parentsUi": {
            "parentIdType": "id",
            "parentId": "{{ $credentials.googleDriveFolderId }}"
          }
        }
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "{{ $credentials.googleDriveOAuth2Api }}",
          "name": "Google Drive Account"
        }
      },
      "typeVersion": 3
    },
    {
      "id": "save-lead-analysis-001",
      "name": "Save Lead Analysis to Drive",
      "type": "n8n-nodes-base.googleDrive",
      "position": [
        1900,
        160
      ],
      "parameters": {
        "operation": "upload",
        "resource": "file",
        "name": "=Lead_Analysis_{{ $('Gmail Trigger').item.json.from.split('@')[1] }}_{{ $now.format('yyyy-MM-dd_HH-mm') }}.txt",
        "binaryData": false,
        "fileContent": "=LEAD ANALYSIS REPORT\n===================\n\nContact Information:\n- Email: {{ $('Gmail Trigger').item.json.from }}\n- Company: {{ $('Gmail Trigger').item.json.from.split('@')[1] }}\n- Subject: {{ $('Gmail Trigger').item.json.subject }}\n- Date: {{ $now }}\n\nLead Analysis:\n{{ $('Lead summary Agent').item.json.output || 'Analysis in progress' }}\n\nWebsite Information:\n{{ $('Markdown').item.json.content ? $('Markdown').item.json.content.substring(0, 1000) + '...' : 'No website content available' }}\n\nLinkedIn Profile:\n{{ $('Find LinkedIn URL').item.json.linkedin_url || 'Not found' }}\n\nNext Steps:\n1. Follow up within 24 hours\n2. Schedule discovery call\n3. Send personalized proposal\n4. Update CRM with interaction notes\n\n---\nGenerated by AI Lead Management System",
        "options": {
          "parentsUi": {
            "parentIdType": "id",
            "parentId": "={{ $('Create Google Drive Folder').item.json.id }}"
          }
        }
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "{{ $credentials.googleDriveOAuth2Api }}",
          "name": "Google Drive Account"
        }
      },
      "typeVersion": 3
    },
    {
      "id": "update-ghl-contact-001",
      "name": "Update GoHighLevel Contact",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        2100,
        160
      ],
      "parameters": {
        "method": "PUT",
        "url": "=https://rest.gohighlevel.com/v1/contacts/{{ $('Add lead to CRM').item.json.contact.id }}",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "goHighLevelApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.goHighLevelApi.accessToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "customFields",
              "value": {
                "lead_analysis": "={{ $('Lead summary Agent').item.json.output }}",
                "website_url": "={{ $('Find website URL').item.json.data.organization.website || '' }}",
                "linkedin_url": "={{ $('Find LinkedIn URL').item.json.linkedin_url || '' }}",
                "analysis_date": "={{ $now }}",
                "drive_folder_id": "={{ $('Create Google Drive Folder').item.json.id }}",
                "analysis_file_id": "={{ $('Save Lead Analysis to Drive').item.json.id }}",
                "lead_score": "High",
                "status": "Analyzed"
              }
            },
            {
              "name": "tags",
              "value": [
                "Analyzed",
                "Website Scraped",
                "High Priority"
              ]
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "goHighLevelApi": {
          "id": "{{ $credentials.goHighLevelApi }}",
          "name": "GoHighLevel API"
        }
      },
      "typeVersion": 4.2
    },
    {
      "id": "ai-agent-main-001",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [
        500,
        400
      ],
      "parameters": {
        "text": "=Analyze this email for GoHighLevel CRM processing:\n\nFrom: {{ $json.from }}\nSubject: {{ $json.subject }}\nContent: {{ $json.textPlain || $json.textHtml }}\n\nDetermine:\n1. Email category (lead, partnership, support, other)\n2. Priority level (high, medium, low)\n3. Suggested response strategy\n4. CRM tags and pipeline placement\n5. Automation triggers needed",
        "options": {
          "systemMessage": "You are a GoHighLevel CRM email processing specialist. Analyze emails to categorize them properly for CRM automation. Focus on lead scoring, pipeline placement, and automation trigger recommendations. Provide structured output for seamless CRM integration.",
          "maxIterations": 3
        }
      },
      "typeVersion": 1.7
    },
    {
      "id": "openai-model-main-001",
      "name": "OpenAI Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenAi",
      "position": [
        320,
        560
      ],
      "parameters": {
        "model": "chatgpt-4o-latest",
        "options": {
          "temperature": 0.4,
          "maxTokens": 1200
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "{{ $credentials.openAiApi }}",
          "name": "OpenAI API"
        }
      },
      "typeVersion": 1
    },
    {
      "id": "structured-parser-001",
      "name": "Structured Output Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "position": [
        460,
        560
      ],
      "parameters": {
        "jsonSchemaExample": "{\n  \"email_category\": \"lead|partnership|support|other\",\n  \"priority\": \"high|medium|low\",\n  \"lead_score\": \"hot|warm|cold\",\n  \"pipeline_stage\": \"New Lead|Contacted|Qualified|Proposal|Closed\",\n  \"suggested_response\": \"Brief response suggestion\",\n  \"crm_tags\": [\"tag1\", \"tag2\", \"tag3\"],\n  \"automation_triggers\": [\"trigger1\", \"trigger2\"],\n  \"next_action\": \"Immediate action required\"\n}"
      },
      "typeVersion": 1.2
    },
    {
      "id": "create-ghl-opportunity-001",
      "name": "Create GoHighLevel Opportunity",
      "type": "n8n-nodes-base.httpRequest",
      "position": [
        700,
        500
      ],
      "parameters": {
        "method": "POST",
        "url": "https://rest.gohighlevel.com/v1/pipelines/{{ $credentials.goHighLevelPipelineId }}/opportunities/",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "goHighLevelApi",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.goHighLevelApi.accessToken }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "title",
              "value": "=Lead Inquiry - {{ $('Gmail Trigger').item.json.from.split('@')[1] }}"
            },
            {
              "name": "contactId",
              "value": "={{ $('Add lead to CRM').item.json.contact.id }}"
            },
            {
              "name": "status",
              "value": "={{ $json.pipeline_stage }}"
            },
            {
              "name": "monetaryValue",
              "value": 5000
            },
            {
              "name": "notes",
              "value": "=Email Subject: {{ $('Gmail Trigger').item.json.subject }}\nAI Analysis: {{ $json.suggested_response }}\nPriority: {{ $json.priority }}\nLead Score: {{ $json.lead_score }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "credentials": {
        "goHighLevelApi": {
          "id": "{{ $credentials.goHighLevelApi }}",
          "name": "GoHighLevel API"
        }
      },
      "typeVersion": 4.2
    },
