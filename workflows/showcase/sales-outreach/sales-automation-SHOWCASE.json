      "position": [
        900,
        500
      ],
      "parameters": {
        "operation": "upload",
        "resource": "file",
        "name": "=Email_Analysis_{{ $('Gmail Trigger').item.json.from.split('@')[1] }}_{{ $now.format('yyyy-MM-dd_HH-mm') }}.json",
