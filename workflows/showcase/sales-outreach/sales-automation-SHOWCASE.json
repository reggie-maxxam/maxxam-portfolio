                    "leftValue": "={{ $('AI Agent').item.json.priority }}",
                    "rightValue": "high"
                  },
                  {
                    "operator": {
                      "type": "string",
                      "operation": "equal"
                    },
                    "leftValue": "={{ $('AI Agent').item.json.lead_score }}",
