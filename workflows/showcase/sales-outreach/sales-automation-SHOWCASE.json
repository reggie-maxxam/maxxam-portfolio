        1300,
        400
      ],
      "parameters": {
        "rules": {
          "values": [
            {
              "outputKey": "high_priority",
              "conditions": {
                "options": {
                  "leftValue": "",
                  "caseSensitive": true,
                  "typeValidation": "strict"
                },
                "combinator": "or",
                "conditions": [
                  {
                    "operator": {
                      "type": "string",
                      "operation": "equal"
